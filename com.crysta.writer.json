{
  "app-id": "com.crysta.writer",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "crysta",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--share=ipc",
    "--share=network",
    "--filesystem=host"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/node24/bin",
    "env": {
      "CARGO_HOME": "/run/build/crysta/cargo",
      "XDG_CACHE_HOME": "/run/build/crysta/flatpak-node/cache",
      "npm_config_cache": "/run/build/crysta/flatpak-node/npm-cache"
    }
  },
  "modules": [
    {
      "name": "crysta",
      "buildsystem": "simple",
      "build-commands": [
        "npm install --offline",
        "npm run build",
        "cargo build --release --offline",
        "install -Dm755 src-tauri/target/release/crysta /app/bin/crysta",
        "install -Dm644 icons/128x128.png /app/share/icons/hicolor/128x128/apps/com.crysta.writer.png",
        "install -Dm644 com.crysta.writer.desktop /app/share/applications/com.crysta.writer.desktop",
        "install -Dm644 com.crysta.writer.metainfo.xml /app/share/metainfo/com.crysta.writer.metainfo.xml"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/RubarMo/Crysta.git",
          "tag": "v2.5.0"
        },
        "cargo-sources.json",
        "node-sources.json"
      ],
      "x-checker-data": {
        "type": "git",
        "tag-pattern": "^v([0-9]+(?:\\.[0-9]+)+)$"
      }
    }
  ]
}
